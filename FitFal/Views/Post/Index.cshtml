@model IQueryable<FitFalMVC.Domain.Model.Post>

<h1>Blog Posts</h1>

@foreach (var item in Model)
{
    <div style="display: flex; align-items: flex-start; margin-bottom: 20px;">
        @if (item.Image != null)
        {
            <img src="data:image;base64,@Convert.ToBase64String(item.Image)" alt="Post Image" width="100" style="margin-right: 20px;" />
        }
        <div>
            <h2>@item.Title</h2>
            <p>@item.Content.Length > 100 ? @item.Content.Substring(0, 100) + "..." : @item.Content</p>
            <a href="/Posts/Details/@item.Id" class="btn btn-primary">Zobacz więcej</a>
        </div>
    </div>
}